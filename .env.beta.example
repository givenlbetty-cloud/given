# ═══════════════════════════════════════════════════════════════════════
# 🚀 ENVIRONNEMENT BETA - VARIABLES DE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# 🔑 SÉCURITÉ - SECRET_KEY DIFFÉRENTE DE PRODUCTION
SECRET_KEY=django-insecure-beta-testing-key-change-this-randomly-64-chars-min

# 🐛 DEBUG MODE (TRUE pour phase de test, FALSE pour déploiement final)
DEBUG=True

# 🌐 DOMAINES AUTORISÉS (Adapter selon votre hébergeur)
# Format: ALLOWED_HOSTS=beta.monprojet.com,localhost,127.0.0.1
ALLOWED_HOSTS=beta.monprojet.com,localhost,127.0.0.1

# 📊 BASE DE DONNÉES BETA (Séparée de production)
# Format: DATABASE_URL=sqlite:///db_beta.sqlite3
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db_beta.sqlite3

# 🔐 AUTHENTIFICATION BASIC AUTH (pour protéger l'accès)
ENABLE_BASIC_AUTH=True
BASIC_AUTH_USERNAME=beta_user
BASIC_AUTH_PASSWORD=change_this_secure_password_12345

# 📁 STOCKAGE DES MÉDIAS BETA (Séparé de production)
MEDIA_ROOT=media_beta
MEDIA_URL=/media_beta/

# 📧 EMAIL (Mode Console pour tests - NE PAS envoyer de vrais emails)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# 💳 SERVICES TIERS - MODE SANDBOX UNIQUEMENT
# Stripe (Mode Test)
STRIPE_PUBLIC_KEY=pk_test_your_test_key_here
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_key_here

# 📱 Autres Services (remplir si utilisés)
TWILIO_ACCOUNT_SID=your_test_account_sid
TWILIO_AUTH_TOKEN=your_test_auth_token

# 🔒 SSL/HTTPS (FALSE en développement, TRUE en production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# 📝 LOGGING (Mode verbose pour déboguer)
LOG_LEVEL=DEBUG

# 🌍 CORS & ORIGINS (Ajouter votre domaine de test)
CSRF_TRUSTED_ORIGINS=https://beta.monprojet.com,http://localhost:8000,http://127.0.0.1:8000

# 📌 INFORMATIONS DE DÉPLOIEMENT
DEPLOYMENT_ENV=beta
DEPLOYMENT_URL=beta.monprojet.com
DEPLOYMENT_PROVIDER=render  # ou 'railway', 'heroku', 'custom-vps'

# ═══════════════════════════════════════════════════════════════════════
# ⚠️  INSTRUCTIONS:
# 1. Copier ce fichier en .env.beta: cp .env.beta.example .env.beta
# 2. Remplir toutes les valeurs
# 3. JAMAIS committer .env.beta sur git
# 4. Ajouter .env.beta au .gitignore
# ═══════════════════════════════════════════════════════════════════════
